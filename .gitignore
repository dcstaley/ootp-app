node_modules/
dist/
web/dist/
*.log

# Personal per-machine Claude Code settings (project settings.json IS committed)
.claude/settings.local.json

# Generated golden reference files (regenerated from captures)
fixtures/golden/*.json

# Frozen active #2 eventForm (the trained model's betas) — local, like captures.
# The #2 regression goldens are generated from it; never commit the trained model.
fixtures/eventform-active.json

# File-based app DB (D7). Tournaments + era/park libraries ARE tracked (the user's real,
# hand-authored config). Card lists (imports), per-account ownership and runtime selection
# state are LOCAL — re-uploaded / regenerated per machine.
data/imports/
data/accounts/
data/state/
data/models/

# data/trained-models/ IS TRACKED (2026-07-20 ruling). These are fit artifacts —
# coefficients, eventForm, platoon, wobaWeights, ratingEnvelope, trainingMeans, diag — and
# carry NO ownership, price or account/economy data, so the privacy reason below does not
# apply to them. They are tracked for PROVENANCE: a retrain that replaces the deployed model
# used to be unrecoverable, and 'league-41-42-pareto' was in fact lost that way on
# 2026-07-20 (only its scorecard output survived, in fixtures/). Every artifact a result was
# measured against must remain reconstructible. They are ~8KB each; if one ever exceeds
# ~1MB, commit a manifest + hash instead of the blob.

# Real captures embed the user's trained model coefficients + account/economy
# data — NEVER commit these. Only the safe invented smoke-test fixture is kept.
fixtures/captures/*.json
!fixtures/captures/.gitkeep
!fixtures/captures/_synthetic.json

# Live training data (per-year league CSVs; grows weekly — keep local)
League Files/

# Real tournament outcome exports (validation/eval data; grows per running — keep local)
Tournament Data/

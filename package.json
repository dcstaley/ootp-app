{
  "name": "ootp-optimizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "OOTP roster optimizer rebuild — one scoring core, computed once, consumed identically.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "golden": "node tools/golden/generate-golden.ts",
    "server": "node src/server/server.ts",
    "dev": "node tools/dev.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "npm run build:web && node src/server/server.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "highs": "^1.14.2",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
